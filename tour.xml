<krpano version="1.23" title="Palermo">

	<include url="skin/vtourskin.xml" />

	<layer name="Photorama"
		type="container"
		bgcolor="0x000000"
		bgalpha="0.5"
		alpha="1"
		keep="true"
		width="200"
		height="121"
		align="lefttop"
		scalechildren="true"
		bgcapture="true"
		expanded="false"
		visible="fasle"
		onclick="if(expanded=='false',
				set (expanded, 'true');
				tween(width, 400, 0.5, easeOutQuad); tween(height, 242, 0.5, easeOutQuad);
				,
				set (expanded, 'false');
				tween(width, 200, 0.5, easeInQuad); tween(height, 121, 0.5, easeInQuad););"
		>
		<layer name="Photorama_mappa"
			type="image"
			url="skin/Photorama_mappa.png"
			align="center"
			width="100%"
			height="prop"
			capture="false" />
		<layer name="d426"
			type="image"
			url="skin/dot.png"
			x="52%"
			y="42%"
			width="4%"
			height="prop"
			capture="false"
			onclick="loadscene(scene_426_palerme_EQUI, MERGE, KEEPVIEW, BLEND(2));" />
		<layer name="d427"
			type="image"
			url="skin/dot.png"
			x="60%"
			y="50%"
			width="4%"
			height="prop"
			capture="false"
			onclick="loadscene(scene_426_palerme_oggi_spostata_EQUI, MERGE, KEEPVIEW, BLEND(2));" />
	</layer>		
	
	<layer name="maps"
		type="image"
		url="skin/Mappa.png"
		style="skin_base|skin_glow"
		scale="0.07"
		keep="true"
		x="10%"
		y="-5%"
		onclick="toggle(layer[Photorama].visible);"
		"if(device.mobile==true, set scale="0.5""/>
	/>

	

	<!-- customize skin settings: maps, gyro, webvr, thumbnails, tooltips, layout, design, ... -->
	<skin_settings maps="false"
	               maps_type="openstreetmaps"
	               maps_bing_api_key=""
	               maps_google_api_key=""
	               maps_zoombuttons="false"
	               maps_loadonfirstuse="true"
	               gyro="true"
	               gyro_keeplookingdirection="false"
	               webvr="false"
	               webvr_keeplookingdirection="true"
	               webvr_prev_next_hotspots="true"
	               autotour="false"
	               littleplanetintro="false"
	               followmousecontrol="false"
	               title="true"
	               thumbs="true"
	               thumbs_width="120" thumbs_height="80" thumbs_padding="10" thumbs_crop="0|40|240|160"
	               thumbs_opened="false"
	               thumbs_text="true"
	               thumbs_dragging="true"
	               thumbs_onhoverscrolling="false"
	               thumbs_scrollbuttons="false"
	               thumbs_scrollindicator="false"
	               thumbs_loop="false"
	               tooltips_buttons="false"
	               tooltips_thumbs="false"
	               tooltips_hotspots="false"
	               tooltips_mapspots="false"
	               deeplinking="false"
	               loadscene_flags="MERGE | KEEPVIEW"
	               loadscene_blend="OPENBLEND(0.5, 0.0, 0.75, 0.05, linear)"
	               loadscene_blend_prev="SLIDEBLEND(0.5, 180, 0.75, linear)"
	               loadscene_blend_next="SLIDEBLEND(0.5,   0, 0.75, linear)"
	               loadingtext=""
	               layout_width="100%"
	               layout_maxwidth="814"
	               controlbar_width="-24"
	               controlbar_height="40"
	               controlbar_offset="20"
	               controlbar_offset_closed="-40"
	               controlbar_overlap.no-fractionalscaling="10"
	               controlbar_overlap.fractionalscaling="0"
	               design_skin_images="vtourskin.png"
	               design_bgcolor="0x2D3E50"
	               design_bgalpha="0.5"
	               design_bgborder="0"
	               design_bgroundedge="0"
	               design_bgshadow="0 4 10 0x000000 0.3"
	               design_thumbborder_bgborder="3 0xFFFFFF 1.0"
	               design_thumbborder_padding="2"
	               design_thumbborder_bgroundedge="0"
	               design_text_css="color:#FFFFFF; font-family:Calibri;"
	               design_text_shadow="1"
	               />

	<!--
	    For an alternative skin design either change the <skin_settings> values 
	    from above or optionally include one of the predefined designs from below.
	-->
	<!-- <include url="skin/vtourskin_design_flat_light.xml"  /> -->
	<!-- <include url="skin/vtourskin_design_glass.xml"       /> -->
	<!-- <include url="skin/vtourskin_design_ultra_light.xml" /> -->
	<!-- <include url="skin/vtourskin_design_117.xml"         /> -->
	<!-- <include url="skin/vtourskin_design_117round.xml"    /> -->
	<!-- <include url="skin/vtourskin_design_black.xml"       /> -->
	

	
	<scene name="scene_426_palerme_oggi_spostata_EQUI" title="426 Le port (n°1) - Oggi" onstart="" thumburl="panos/426_Palerme_oggi_spostata_EQUI.tiles/thumb.jpg" lat="" lng="" alt="" heading="">
		
		<control bouncinglimits="calc:image.cube ? true : false" />

		<view hlookat="149.697" vlookat="6.386" fovtype="MFOV" fov="120.000" maxpixelzoom="2.0" fovmin="70" fovmax="140" limitview="range" vlookatmin="-62.519" vlookatmax="62.490" />

		<preview url="panos/426_Palerme_oggi_spostata_EQUI.tiles/preview.jpg" />

		<image>
			<cube url="panos/426_Palerme_oggi_spostata_EQUI.tiles/%s/l%l/%v/l%l_%s_%v_%h.jpg" multires="512,1024,2048,4096" />
		</image>

	</scene>

	<scene name="scene_426_palerme_EQUI" title="426 Le port (n°1) - 1900 Lumière" onstart="" thumburl="panos/426_Palerme_EQUI.tiles/thumb.jpg" lat="" lng="" alt="" heading="">
		
		<control bouncinglimits="calc:image.cube ? true : false" />

		<view hlookat="0.0" vlookat="0.0" fovtype="MFOV" fov="120" maxpixelzoom="2.0" fovmin="70" fovmax="140" limitview="range" vlookatmin="-30" vlookatmax="30" />

		<preview url="panos/426_Palerme_EQUI.tiles/preview.jpg" />

		<image>
			<cube url="panos/426_Palerme_EQUI.tiles/%s/l%l/%v/l%l_%s_%v_%h.jpg" multires="512,768,1536" />
		</image>
		
		<hotspot name="spot1" type="image"
	   		url="skin/info_n.png"
	    		scale="0.08"
	       		ath="-80"
			atv="-10"
			onclick="toggle(layer[box].visible); toggle(layer[img1].visible); toggle(layer[testo].visible);"/>
		<layer name="box" type="container"
	   		bgcolor="0x000000"
			bgalpha="0.4"
			alpha="1"
			width="400"
			height="300"
			visible="false"
	       		align="center"
			children="true"
			capture="false">
			<layer name="img1" type="image"
	   			url="skin/Castelloamare.jpg"
	    			scale="0.3"
				align="center"
				visible="false"
				capture="false"
				onclick="toggle(layer[box].visible); toggle(layer[img1].visible); toggle(layer[testo].visible);"/>
			<layer name="testo" type="text"
				align="bottom"
				text="Castello a mare"
				css="font-family:Calibri; font-size:14px; color:#FFFFFF;"
				bgalpha="0"
				visible="false"
				capture="false" />
		</layer>
	</scene>


</krpano>
