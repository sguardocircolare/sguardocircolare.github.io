		<layer name="oggi" type="image" url="skin/OGGI.png" style="skin_base|skin_glow" parent="skin_control_bar" align="center" x="0" y="0" scale="0.06" onclick="loadscene('scene_427_palerme_oggi_spostata_EQUI', MERGE, KEEPVIEW, BLEND(1));" />

	</scene>

</krpano>
